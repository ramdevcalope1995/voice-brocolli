PORT=3000
CORS_ORIGIN=http://localhost:4200

# MongoDB (required for app startup)
MONGODB_URI=mongodb://127.0.0.1:27017/wubble-demo

# Upstash Redis — AI cache / short-term context (https://console.upstash.com/redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Upstash Vector — semantic memory (https://console.upstash.com/vector)
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=
# Optional namespace inside the index
UPSTASH_VECTOR_NAMESPACE=

# QStash — workflows / delayed jobs (https://console.upstash.com/qstash)
QSTASH_TOKEN=
# Optional override (default https://qstash.upstash.io)
QSTASH_URL=
# Webhook signature verification (Receiver tab in QStash console)
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Local auth uses MongoDB user and session collections.

# GetStream Video (https://dashboard.getstream.io)
STREAM_API_KEY=
STREAM_API_SECRET=
STREAM_TOKEN_VALIDITY_SECONDS=3600

# Spawn Python agent on each POST /sales-demo/session (set to false to run agent manually)
SALES_DEMO_SPAWN_AGENT=true
AGENT_PYTHON=python3

# Wubble realtime voice (see backend/wubble-stream-agent/README.md)
WUBBLE_API_KEY=
WUBBLE_WS_URL=

# Vercel AI Gateway / Gemini notebook chat
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=google/gemini-2.0-flash

# Python agent: short tone after join when true
AGENT_PLACEHOLDER_TONE=true
